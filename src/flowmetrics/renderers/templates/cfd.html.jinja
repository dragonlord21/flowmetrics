{% extends "base.html.jinja" %}

{% block subtitle %}
<p class="subtitle">
  for
  {%- if repo_url %} <a href="{{ repo_url }}">{{ report.input.repo }}</a>
  {%- else %} {{ report.input.repo }}
  {%- endif %} ·
  {{ report.input.start }} → {{ report.input.stop }} ·
  <span class="stamp">generated {{ generated_at.strftime("%Y-%m-%d %H:%M %Z").strip() }}</span>
</p>
{% endblock %}

{# Suppress the auto-rendered top-of-page blocks. The title (h1) +
   subtitle already carry repo / window / stamp; the chart + bookends
   carry the visual answer; everything else folds into the About
   collapsible. Same minimal-head treatment as the Aging report. #}
{% block headline %}{% endblock %}
{% block definition %}{% endblock %}
{% block banner %}{% endblock %}
{% block key_insight %}{% endblock %}
{% block next_actions %}{% endblock %}
{% block caveats %}{% endblock %}
{% block reproduce %}{% endblock %}
{% block vocabulary %}{% endblock %}

{% block content %}
{% if not report.points %}
<p>No CFD samples for this window.</p>
{% else %}

{# Workflow bookends — the entry (intake) and exit (terminal) states
   are the two ends of the system. They're supposed to balance over
   time: cumulative arrivals ≈ cumulative departures keeps WIP
   roughly flat. Show the whole flow as a pill chain so readers see
   the assumed order before reading the chart. Order is supplied by
   the user via --workflow; the system trusts it. #}
<div class="workflow-bookends">
  <div class="bookend-label entry">Entering →</div>
  <div class="workflow-chain">
    {% for s in report.input.workflow -%}
      <span class="pill
        {%- if loop.first %} pill-entry
        {%- elif loop.last %} pill-exit
        {%- endif %}">{{ s }}</span>
      {%- if not loop.last %} <span class="arrow">→</span> {% endif %}
    {%- endfor %}
  </div>
  <div class="bookend-label exit">→ Exiting</div>
</div>

<div id="cfd-chart" class="chart tall"></div>
<script src="https://cdn.jsdelivr.net/npm/vega@5"></script>
<script src="https://cdn.jsdelivr.net/npm/vega-lite@5"></script>
<script src="https://cdn.jsdelivr.net/npm/vega-embed@6"></script>
<script>
  vegaEmbed("#cfd-chart", {{ vega_spec_json | safe }}, {
    actions: {export: true, source: false, compiled: false, editor: false},
    renderer: "svg"
  }).then(function(result) {
    // Horizontal y-axis guideline: a dashed line + label that follows
    // the cursor's vertical position over the chart. Reads the y-axis
    // value at the cursor without bouncing the eye back to tick labels.
    // Vega-Lite doesn't expose a cursor-y signal natively, so we use
    // the rendered SVG plus Vega's `view.scale('y').invert(pixel)` to
    // translate screen-y → data value.
    var container = document.getElementById("cfd-chart");
    var svg = container.querySelector("svg");
    if (!svg) return;
    var view = result.view;
    var ns = "http://www.w3.org/2000/svg";
    var overlay = document.createElementNS(ns, "g");
    overlay.setAttribute("data-flow", "y-guideline");
    overlay.setAttribute("pointer-events", "none");
    overlay.style.opacity = "0";
    overlay.style.transition = "opacity 80ms";
    var line = document.createElementNS(ns, "line");
    line.setAttribute("stroke", "#444");
    line.setAttribute("stroke-width", "1");
    line.setAttribute("stroke-dasharray", "3 3");
    line.setAttribute("opacity", "0.65");
    overlay.appendChild(line);
    var labelBg = document.createElementNS(ns, "rect");
    labelBg.setAttribute("fill", "white");
    labelBg.setAttribute("opacity", "0.85");
    overlay.appendChild(labelBg);
    var label = document.createElementNS(ns, "text");
    label.setAttribute("data-flow", "y-guideline-label");
    label.setAttribute("font-size", "11");
    label.setAttribute("font-weight", "bold");
    label.setAttribute("fill", "#222");
    overlay.appendChild(label);
    svg.appendChild(overlay);

    function plotBox() {
      // Vega-Lite's SVG: <svg> > <g translate(margin)> > <g.role-frame>
      // > <path.background>. The plot interior is the background path's
      // bbox in svg-document coords (getCTM accounts for parent
      // translates).
      var bg = svg.querySelector(".role-frame .background");
      if (!bg) return null;
      var b = bg.getBBox();
      var ctm = bg.getCTM();
      var tx = ctm ? ctm.e : 0;
      var ty = ctm ? ctm.f : 0;
      return {
        left: tx + b.x,
        top: ty + b.y,
        right: tx + b.x + b.width,
        bottom: ty + b.y + b.height,
        width: b.width,
        height: b.height,
      };
    }

    function onMove(e) {
      var rect = svg.getBoundingClientRect();
      var svgX = (e.clientX - rect.left) * (svg.viewBox.baseVal.width || svg.clientWidth) / rect.width;
      var svgY = (e.clientY - rect.top) * (svg.viewBox.baseVal.height || svg.clientHeight) / rect.height;
      var box = plotBox();
      if (!box) return;
      if (svgY < box.top || svgY > box.bottom || svgX < box.left || svgX > box.right) {
        overlay.style.opacity = "0";
        return;
      }
      // Invert pixel-y → data value. yScale takes pixel-in-plot, where
      // y=0 is the TOP of the plot area (Vega convention). So invert
      // (svgY - box.top).
      var yScale = view.scale("y");
      if (!yScale) { overlay.style.opacity = "0"; return; }
      var dataY;
      try { dataY = yScale.invert(svgY - box.top); }
      catch (_) { overlay.style.opacity = "0"; return; }
      // Draw line across the plot area.
      line.setAttribute("x1", box.left);
      line.setAttribute("x2", box.right);
      line.setAttribute("y1", svgY);
      line.setAttribute("y2", svgY);
      // Label just above the line, on the LEFT inside the plot, with a
      // small white bg so it sits over the data legibly.
      var labelText = Math.round(dataY).toString();
      label.textContent = labelText;
      label.setAttribute("x", box.left + 6);
      label.setAttribute("y", svgY - 4);
      // Size the bg rect to the label.
      try {
        var lbox = label.getBBox();
        labelBg.setAttribute("x", lbox.x - 2);
        labelBg.setAttribute("y", lbox.y - 1);
        labelBg.setAttribute("width", lbox.width + 4);
        labelBg.setAttribute("height", lbox.height + 2);
      } catch (_) {}
      overlay.style.opacity = "1";
    }
    function onLeave() { overlay.style.opacity = "0"; }
    svg.addEventListener("mousemove", onMove);
    svg.addEventListener("mouseleave", onLeave);
  }).catch(function(err) {
    document.getElementById("cfd-chart").innerText =
      "Interactive chart failed to render: " + err;
  });
</script>

<p class="footnote-tight">
Hover anywhere on the chart to see the per-step WIP and total
items-in-flight for that date. Each column is a <em>snapshot</em>
taken on that date, not a range — the chart steps to the next
snapshot only when the next sample arrives.
</p>

{% endif %}
{% endblock %}

{% block detail %}
<details>
<summary>Reproduce this report</summary>
<table>
  <tr><th>Repo</th><td>{{ report.input.repo }}</td></tr>
  <tr><th>Workflow</th><td>
    {% for s in report.input.workflow %}<span class="pill">{{ s }}</span>{% if not loop.last %} → {% endif %}{% endfor %}
  </td></tr>
  <tr><th>Window</th><td>{{ report.input.start }} → {{ report.input.stop }}</td></tr>
  <tr><th>Sample interval</th><td>{{ report.input.interval_days }} day(s)</td></tr>
</table>
<div class="invocation">{{ invocation }}</div>
</details>

<details>
<summary>About this report</summary>
<p><strong>What this shows.</strong> {{ definition }}</p>

<p><strong>How to read the chart.</strong></p>
<ul class="compact-prose">
  <li>Each column is a <em>snapshot</em> taken on that date — every
      band's height is the count of items currently in that workflow
      step at that moment. Slide horizontally and you're watching the
      same set of pipelines change over time.</li>
  <li>The <em>top band</em> is items currently in the first workflow
      step ({{ report.input.workflow[0] }} for this report). That's
      where new arrivals land — items enter the system into this
      band. Anything not yet in the workflow (e.g., a Jira ticket
      that hasn't been filed; a PR not yet opened) is not on this
      chart.</li>
  <li>The team picks which states count as "in flight": that's the
      <code>--workflow</code> list above. A state like
      <em>Triage Needed</em> reads differently depending on whether
      the team treats triage as work (then it belongs on the chart)
      or as a queue waiting for someone to start (then it doesn't).
      The tool renders whatever you've told it; choose the states
      that match your team's agreed definition of WIP.</li>
  <li>The <em>bottom band</em> is items that have reached the final
      step ({{ report.input.workflow[-1] }}) — finished, accumulating
      forever.</li>
  <li>The <em>total height</em> at any date = cumulative items that
      have ever entered the system (top line, including the finished
      ones at the bottom).</li>
  <li>The <em>vertical gap</em> between the top edge and the bottom
      edge = items still in flight (WIP). A widening gap means
      arrivals are outrunning departures; narrowing means the
      opposite.</li>
  <li>The <em>steeper</em> a band's edge, the faster items are
      flowing into that step at that moment.</li>
  <li>The <em>horizontal gap</em> between two adjacent lines at the
      same height tells you roughly how long items spent in the
      stages between them — a wide gap is a slow pipeline.</li>
</ul>

{% if interpretation.key_insight %}
<p><strong>Key insight.</strong> {{ interpretation.key_insight }}</p>
{% endif %}

{% if interpretation.next_actions %}
<p><strong>Next actions</strong></p>
<ol class="compact-prose">
{% for action in interpretation.next_actions %}
  <li>{{ action }}</li>
{% endfor %}
</ol>
{% endif %}

{% if interpretation.caveats %}
<p><strong>Caveats</strong></p>
<ul class="footnote-wider">
{% for c in interpretation.caveats %}
  <li>{{ c }}</li>
{% endfor %}
</ul>
{% endif %}

<p><strong>Vocabulary</strong></p>
<dl>
{% for term, defn in vocabulary.items() %}
  <dt><strong>{{ term }}</strong></dt>
  <dd>{{ defn }}</dd>
{% endfor %}
</dl>
</details>

<details>
<summary>Show all {{ report.points|length }} sample points</summary>
<table>
<thead>
<tr><th>Date</th>{% for s in report.input.workflow %}<th>{{ s }}</th>{% endfor %}</tr>
</thead>
<tbody>
{% for p in report.points %}
  <tr>
    <td>{{ p.sampled_on }}</td>
    {% for s in report.input.workflow %}
      <td class="num">{{ p.counts_by_state.get(s, 0) }}</td>
    {% endfor %}
  </tr>
{% endfor %}
</tbody>
</table>
</details>
{% endblock %}
