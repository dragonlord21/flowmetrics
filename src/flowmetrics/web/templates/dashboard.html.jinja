{% extends "_base.html.jinja" %}

{% block content %}
  {# Each metric tile lazy-loads via HTMX from
     `/api/internal/dashboard-tile/{metric}`. The dashboard route
     returns instantly with these stubs; tiles fill in as their
     server-side renders complete. Per-tile failures don't block
     the page.

     `request.url.query` carries the filter params (period /
     anchor / view_days / ref_days) so the selected window
     propagates to each tile. #}
  {%- set q = request.url.query -%}
  {%- set qs = ('&' + q) if q else '' -%}

  <p class="dashboard-datasource">
    <a href="/workflows/{{ contract.name }}/data-source">Data source &amp; backfill →</a>
  </p>

  {% for slug, label in [
    ('aging', 'Aging WIP'),
    ('throughput', 'Throughput'),
    ('cfd', 'Cumulative Flow'),
    ('cycle-time', 'Cycle time'),
    ('forecast', 'Forecast'),
  ] %}
    <section class="metric metric-loading"
             hx-get="/api/internal/dashboard-tile/{{ slug }}?workflow={{ contract.name }}{{ qs }}"
             hx-trigger="load"
             hx-swap="outerHTML swap:180ms">
      <p class="metric-loading-text">Loading {{ label }}…</p>
    </section>
  {% endfor %}
{% endblock %}
