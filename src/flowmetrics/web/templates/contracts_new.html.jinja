{% extends "_base.html.jinja" %}

{# New-contract wizard. Three fieldsets visible at once (no
   navigation between steps) — name + source + window. Source
   probe fires on blur of the repo / jira_project field. Save
   validates, PUTs, and redirects to the new dashboard. #}

{% block filter_bar %}{% endblock %}
{% block data_source_strip %}{% endblock %}

{% block content %}
<style>
  .wizard {
    max-width: 38rem;
    margin: 1.5rem 0;
  }
  .wizard fieldset {
    border: 0.0625rem solid var(--border);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem 0.5rem 1.25rem;
    margin: 0 0 1.25rem 0;
  }
  .wizard legend {
    font-family: var(--head-font);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--p-600);
    padding: 0 0.4rem;
  }
  .wizard label {
    display: block;
    margin: 0.4rem 0;
    font-size: 0.875rem;
    color: var(--muted);
  }
  .wizard label > input,
  .wizard label > select {
    display: block;
    width: 100%;
    margin-top: 0.2rem;
    padding: 0.4rem 0.5rem;
    border: 0.0625rem solid var(--border);
    border-radius: 0.25rem;
    font-size: 1rem;
    color: var(--fg);
    background: var(--white);
  }
  .source-fields[data-source="jira"] .source-github,
  .source-fields[data-source="github"] .source-jira {
    display: none;
  }
  .probe-status {
    font-size: 0.8125rem;
    margin-top: 0.3rem;
    min-height: 1.1rem;
  }
  .probe-status--ok { color: var(--p-600); }
  .probe-status--fail { color: var(--t-700); }
  .wizard-actions {
    display: flex;
    gap: 0.75rem;
    margin: 0 0 1rem 0;
  }
  .wizard-actions button[type="submit"] {
    background: var(--p-500);
    color: var(--white);
    border: 0;
    padding: 0.45rem 1.1rem;
    border-radius: 0.3rem;
    font-weight: 600;
    cursor: pointer;
  }
  .wizard-actions button[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .wizard-errors {
    color: var(--t-700);
    font-size: 0.875rem;
    margin: 0.5rem 0 0 0;
    min-height: 1.2rem;
  }
</style>

{% if wizard_mode == "edit" %}
<h1>Edit workflow: {{ edit_id }}</h1>
<p class="muted">
  Save overwrites the existing YAML. Delete removes it (warehouse
  data on disk requires explicit purge — the button asks).
</p>
{% else %}
<h1>New workflow</h1>
<p class="muted">
  A workflow is a YAML file under <code>contracts/</code>. Fill in the
  fields below; we'll write it for you and open the dashboard.
</p>
{% endif %}

<form class="wizard" id="wizard">
  <fieldset>
    <legend>Identity</legend>
    <label>Routing ID (lowercase, dashes only)
      <input type="text" name="name" required pattern="[a-z0-9-]+"
             placeholder="astral-uv-week">
    </label>
    <label>Display label (optional)
      <input type="text" name="label" placeholder="Astral uv weekly">
    </label>
  </fieldset>

  <fieldset class="source-fields" data-source="github" id="source-fieldset">
    <legend>Source</legend>
    <label>Source kind
      <select name="source" onchange="document.getElementById('source-fieldset').dataset.source=this.value">
        <option value="github" selected>GitHub</option>
        <option value="jira">Jira</option>
      </select>
    </label>

    <div class="source-github">
      <label>Repository (owner/name)
        <input type="text" name="repo" placeholder="astral-sh/uv"
               onblur="probeSource()">
      </label>
    </div>

    <div class="source-jira">
      <label>Jira base URL
        <input type="text" name="jira_url"
               placeholder="https://issues.apache.org/jira"
               onblur="probeSource()">
      </label>
      <label>Project key
        <input type="text" name="jira_project" placeholder="BIGTOP"
               onblur="probeSource()">
      </label>
    </div>

    <div class="probe-status" id="probe-status"></div>
  </fieldset>

  <fieldset id="steps-fieldset">
    <legend>Steps (optional)</legend>
    <p class="muted" style="font-size: 0.8125rem; margin: 0 0 0.6rem 0;">
      Define the workflow as an ordered list of steps. Toggle WIP
      per step — leading non-WIP rows render as
      <strong style="color: var(--muted);">READY</strong>, the
      contiguous WIP block as
      <strong style="color: var(--p-600);">WIP</strong>, and
      trailing non-WIP rows as
      <strong style="color: var(--muted);">DONE</strong>. Use ↑/↓
      to reorder.
    </p>
    <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem;">
      <button type="button" class="filter-apply" onclick="probeStages()">Discover from data source</button>
      <span class="probe-status" id="stages-status"></span>
    </div>
    <ol id="steps-list"
        style="list-style: none; padding: 0; margin: 0; border: 0.0625rem solid var(--border); border-radius: 0.25rem;"></ol>
    <div style="margin-top: 0.6rem; display: flex; gap: 0.4rem;">
      <input type="text" id="new-step-name" placeholder="Step name (e.g. In Progress)"
             style="flex: 1; padding: 0.3rem 0.5rem; border: 0.0625rem solid var(--border); border-radius: 0.25rem;">
      <label style="display: flex; align-items: center; gap: 0.3rem; font-size: 0.875rem;">
        <input type="checkbox" id="new-step-wip" checked>
        WIP
      </label>
      <button type="button" id="add-step" onclick="addStep()">+ Add step</button>
    </div>
  </fieldset>

  <fieldset>
    <legend>Window (optional)</legend>
    <label>Start (YYYY-MM-DD)
      <input type="date" name="start">
    </label>
    <label>Stop (YYYY-MM-DD)
      <input type="date" name="stop">
    </label>
  </fieldset>

  <div class="wizard-actions">
    <button type="submit">{% if wizard_mode == "edit" %}Save{% else %}Save &amp; open{% endif %}</button>
    <a href="/" class="filter-reset">Cancel</a>
    {% if wizard_mode == "edit" %}
    <button type="button" id="archive-btn"
            style="margin-left: auto; background: transparent; border: 0.0625rem solid var(--t-700); color: var(--t-700); padding: 0.4rem 1rem; border-radius: 0.3rem; cursor: pointer;"
            onclick="confirmArchive()">Archive</button>
    {% endif %}
  </div>
  <p class="wizard-errors" id="wizard-errors"></p>
</form>

<script>
  // -----------------------------------------------------------------
  // Steps editor: one ordered list, each row = {name, wip}.
  // READY / WIP / DONE badges derive from order + wip flag on render.
  // -----------------------------------------------------------------

  function readSteps() {
    var rows = document.querySelectorAll('#steps-list li[data-step]');
    var out = [];
    rows.forEach(function (li) {
      var name = li.querySelector('input.step-name').value.trim();
      if (!name) return;
      out.push({
        name: name,
        wip: li.querySelector('input.step-wip').checked,
      });
    });
    return out;
  }

  function categoryBadge(idx, steps) {
    // Walk forward; the first WIP row ends READY. After any WIP
    // is seen, every non-WIP row is DONE.
    var seenWip = false;
    for (var i = 0; i <= idx; i++) {
      if (steps[i].wip) seenWip = true;
    }
    if (steps[idx].wip) return { text: 'WIP', color: 'var(--p-600)' };
    return seenWip
      ? { text: 'DONE', color: 'var(--muted)' }
      : { text: 'READY', color: 'var(--muted)' };
  }

  function refreshBadges() {
    var steps = readSteps();
    var rows = document.querySelectorAll('#steps-list li[data-step]');
    rows.forEach(function (li, idx) {
      var span = li.querySelector('.step-badge');
      if (!span || idx >= steps.length) return;
      var b = categoryBadge(idx, steps);
      span.textContent = b.text;
      span.style.color = b.color;
    });
  }

  function renderStepRow(name, wip) {
    var li = document.createElement('li');
    li.dataset.step = '1';
    li.style.cssText = 'display: flex; align-items: center; gap: 0.4rem; ' +
      'padding: 0.4rem 0.5rem; border-bottom: 0.0625rem solid var(--border); ' +
      'background: var(--white);';

    var badge = document.createElement('span');
    badge.className = 'step-badge';
    badge.style.cssText = 'min-width: 3rem; font-size: 0.65rem; ' +
      'font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;';
    li.appendChild(badge);

    var nameInput = document.createElement('input');
    nameInput.type = 'text';
    nameInput.className = 'step-name';
    nameInput.value = name;
    nameInput.style.cssText = 'flex: 1; padding: 0.2rem 0.4rem; ' +
      'border: 0.0625rem solid var(--border); border-radius: 0.2rem;';
    li.appendChild(nameInput);

    var wipLabel = document.createElement('label');
    wipLabel.style.cssText = 'display: flex; align-items: center; gap: 0.25rem; font-size: 0.8125rem;';
    var wipInput = document.createElement('input');
    wipInput.type = 'checkbox';
    wipInput.className = 'step-wip';
    wipInput.checked = !!wip;
    wipInput.addEventListener('change', refreshBadges);
    wipLabel.appendChild(wipInput);
    wipLabel.appendChild(document.createTextNode('WIP'));
    li.appendChild(wipLabel);

    var up = document.createElement('button');
    up.type = 'button';
    up.textContent = '↑';
    up.style.cssText = 'font-size: 0.8rem; padding: 0.15rem 0.4rem;';
    up.onclick = function () {
      var prev = li.previousElementSibling;
      if (prev) li.parentElement.insertBefore(li, prev);
      refreshBadges();
    };
    li.appendChild(up);

    var down = document.createElement('button');
    down.type = 'button';
    down.textContent = '↓';
    down.style.cssText = 'font-size: 0.8rem; padding: 0.15rem 0.4rem;';
    down.onclick = function () {
      var next = li.nextElementSibling;
      if (next) li.parentElement.insertBefore(next, li);
      refreshBadges();
    };
    li.appendChild(down);

    var del = document.createElement('button');
    del.type = 'button';
    del.textContent = '×';
    del.style.cssText = 'font-size: 0.8rem; padding: 0.15rem 0.4rem; color: var(--muted);';
    del.onclick = function () {
      li.parentElement.removeChild(li);
      refreshBadges();
    };
    li.appendChild(del);

    return li;
  }

  function addStep(name, wip) {
    if (name === undefined) {
      var input = document.getElementById('new-step-name');
      name = (input.value || '').trim();
      if (!name) return;
      wip = document.getElementById('new-step-wip').checked;
      input.value = '';
    }
    document.getElementById('steps-list').appendChild(renderStepRow(name, !!wip));
    refreshBadges();
  }

  function probeStages() {
    var data = readForm();
    var status = document.getElementById('stages-status');
    status.textContent = 'Discovering…';
    status.className = 'probe-status';
    fetch('/api/internal/contracts/_probe-stages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'fetch',
      },
      body: JSON.stringify(data),
    }).then(function (r) { return r.json(); }).then(function (body) {
      var stages = body.stages || [];
      stages.forEach(function (name) {
        // Discovered stages default to WIP; user toggles as needed.
        addStep(name, true);
      });
      if (body.hint) {
        status.textContent = body.hint;
        status.className = 'probe-status';
      } else {
        status.textContent = '✓ ' + stages.length + ' stages discovered';
        status.className = 'probe-status probe-status--ok';
      }
    });
  }

  function buildYaml(data) {
    // Compose the YAML body from the form fields. The server's
    // PUT endpoint re-parses this against parse_contract_text, so
    // anything malformed surfaces as a 422.
    var lines = ["contract:"];
    lines.push("  name: " + data.name);
    if (data.label) lines.push("  label: " + JSON.stringify(data.label));
    lines.push("  source: " + data.source);
    if (data.source === "github" && data.repo) {
      lines.push("  repo: " + data.repo);
    }
    if (data.source === "jira") {
      if (data.jira_url) lines.push("  jira_url: " + data.jira_url);
      if (data.jira_project) lines.push("  jira_project: " + data.jira_project);
    }
    if (data.start) lines.push("  start: " + data.start);
    if (data.stop) lines.push("  stop: " + data.stop);
    var steps = readSteps();
    if (steps.length) {
      lines.push("  steps:");
      steps.forEach(function (s) {
        lines.push("    - name: " + JSON.stringify(s.name));
        lines.push("      wip: " + (s.wip ? "true" : "false"));
      });
    }
    return lines.join("\n") + "\n";
  }

  function readForm() {
    var f = document.getElementById("wizard");
    var data = {};
    new FormData(f).forEach(function (v, k) { data[k] = v; });
    return data;
  }

  function probeSource() {
    var data = readForm();
    if (!data.source) return;
    var status = document.getElementById("probe-status");
    status.textContent = "Checking…";
    status.className = "probe-status";
    fetch("/api/internal/contracts/_probe-source", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "X-Requested-With": "fetch",
      },
      body: JSON.stringify(data),
    }).then(function (r) { return r.json(); }).then(function (body) {
      if (body.ok) {
        status.textContent = "✓ " + (body.label || "target reachable");
        status.className = "probe-status probe-status--ok";
      } else {
        status.textContent = "✗ " + (body.error || "target not reachable");
        status.className = "probe-status probe-status--fail";
      }
    }).catch(function (err) {
      status.textContent = "probe failed: " + err;
      status.className = "probe-status probe-status--fail";
    });
  }

  var WIZARD_MODE = {{ wizard_mode | tojson }};
  var EDIT_ID = {{ edit_id | tojson }};

  function hydrateFromExisting(id) {
    fetch("/api/internal/contracts/" + encodeURIComponent(id))
      .then(function (r) { return r.json(); })
      .then(function (body) {
        var form = document.getElementById("wizard");
        var p = body.parsed || {};
        function setField(name, value) {
          var el = form.elements[name];
          if (!el) return;
          if (value !== null && value !== undefined) el.value = value;
        }
        setField("name", p.name);
        setField("label", p.label);
        setField("source", p.source);
        setField("repo", p.repo);
        setField("jira_url", p.jira_url);
        setField("jira_project", p.jira_project);
        setField("start", p.start);
        setField("stop", p.stop);
        // Toggle conditional fields based on the loaded source.
        document.getElementById("source-fieldset").dataset.source = p.source || "github";
        // Hydrate steps into the ordered list. The C1 detail
        // endpoint synthesises `states: {backlog, wip, done}` from
        // the canonical `steps:` for back-compat; rebuild the
        // ordered list here in the same READY → WIP → DONE order.
        if (p.states) {
          (p.states.backlog || []).forEach(function (n) { addStep(n, false); });
          (p.states.wip || []).forEach(function (n) { addStep(n, true); });
          (p.states.done || []).forEach(function (n) { addStep(n, false); });
        }
        // The id is fixed in edit mode; lock the field.
        if (WIZARD_MODE === "edit") {
          form.elements.name.readOnly = true;
        }
      });
  }

  function confirmArchive() {
    // Archive (soft delete) — the contract goes to /admin/contracts/archive
    // where it can be restored or hard-deleted later. The warehouse data
    // is untouched by archive; permanent erasure is a separate flow.
    var reason = window.prompt(
      "Archive '" + EDIT_ID + "'? Optional reason for the audit log:",
      ""
    );
    if (reason === null) return; // cancelled
    fetch(
      "/api/internal/contracts/" + encodeURIComponent(EDIT_ID) + "/archive",
      {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-Requested-With": "fetch",
        },
        body: JSON.stringify({ reason: reason || null }),
      }
    ).then(function (r) {
      if (r.ok) { window.location.href = "/"; return; }
      r.json().then(function (body) {
        document.getElementById("wizard-errors").textContent =
          (body.detail && body.detail.message) || body.detail || "archive failed";
      });
    });
  }

  if (WIZARD_MODE === "edit" && EDIT_ID) {
    hydrateFromExisting(EDIT_ID);
  }

  document.getElementById("wizard").addEventListener("submit", function (ev) {
    ev.preventDefault();
    var errs = document.getElementById("wizard-errors");
    errs.textContent = "";
    var data = readForm();
    var yamlText = buildYaml(data);
    fetch("/api/internal/contracts/" + encodeURIComponent(data.name), {
      method: "PUT",
      headers: {
        "Content-Type": "application/json",
        "X-Requested-With": "fetch",
      },
      body: JSON.stringify({ yaml: yamlText }),
    }).then(function (r) {
      if (r.ok) {
        window.location.href = "/workflows/" + encodeURIComponent(data.name);
        return;
      }
      return r.json().then(function (body) {
        var msg = (body.detail && body.detail.message) || body.detail || "save failed";
        errs.textContent = msg;
      });
    });
  });
</script>
{% endblock %}
