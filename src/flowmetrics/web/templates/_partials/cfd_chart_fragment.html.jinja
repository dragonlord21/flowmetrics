{# CFD chart fragment: chart container + Vega-Lite embed.
   Used inside the tile partial AND returned from
   `/api/internal/cfd` as the HTMX swap payload.

   Required context:
     data           — CfdModel (rendered to a spec via the
                      `vega_spec` Jinja global)
     chart_height   — int pixels (~320 for tile, ~440 for detail)
     workflow.name  — for any back-links
#}
{%- set chart_container_id = "cfd-chart" -%}
{%- set _h = chart_height|default(320) -%}

<div id="{{ chart_container_id }}" class="metric-chart"
     data-chart-height="{{ _h }}">
  {% if not data.daily %}
    <p class="aging-empty">
      No transitions captured yet.
    </p>
  {% endif %}
</div>
{% if data.daily %}
<script>
  (function () {
    if (window.__flowmetricsCfdView) {
      try { window.__flowmetricsCfdView.finalize(); }
      catch (e) { /* finalize is best-effort */ }
      window.__flowmetricsCfdView = null;
    }
    const METRICS = {{ cfd_daily_metrics(data) | safe }};
    const spec = {{ vega_spec(data) | safe }};
    spec.height = {{ _h }};
    // Bottom-orient legend stays on both tile and detail so the
    // reader can map a band colour back to its stage name without
    // hovering. (The earlier top-right orientation collided with
    // the bands and the per-band labels; bottom sits under the
    // x-axis with no overlap.)
    function embed() {
      vegaEmbed("#{{ chart_container_id }}", window.applyTheme(spec), {
        actions: false,
        renderer: "svg"
      }).then(function (res) {
        window.__flowmetricsCfdView = res.view;
        setupCfdHover(res.view, METRICS);
      }).catch(function (err) {
        const el = document.getElementById("{{ chart_container_id }}");
        el.innerText = "Chart render failed: " + err;
      });
    }
    // Defer one frame so the side panel (parsed AFTER this inline script
    // on first load) is laid out before Vega measures the container —
    // otherwise the chart renders at full width and overflows the panel.
    if (window.requestAnimationFrame) { requestAnimationFrame(embed); }
    else { embed(); }

    // Vertical guideline + floating-panel readout linked to the
    // x-axis. Hovering snaps a dashed rule to the nearest day and
    // fills the floating panel with that day's flow metrics; the
    // panel always parks on the side of the rule with more room so
    // it can't occlude the date line itself. Clicking pins the
    // panel to that day (solid rule, outlined panel); clicking the
    // same day again releases. Reads the rendered SVG + Vega's x
    // scale — no extra round-trip.
    function setupCfdHover(view, metrics) {
      const container = document.getElementById("{{ chart_container_id }}");
      const svg = container && container.querySelector("svg");
      if (!svg) return;
      const ns = "http://www.w3.org/2000/svg";
      const rule = document.createElementNS(ns, "line");
      rule.setAttribute("data-flow", "x-guideline");
      // The rule crosses the dark "above" zone AND the lighter bands;
      // mid-grey at 0.85 reads against both without dominating.
      rule.setAttribute("stroke", "rgba(20, 20, 20, 0.85)");
      rule.setAttribute("stroke-width", "1");
      rule.setAttribute("stroke-dasharray", "3 3");
      rule.setAttribute("pointer-events", "none");
      rule.style.opacity = "0";
      rule.style.transition = "opacity 80ms";
      svg.appendChild(rule);

      let pinnedIso = null;
      // Which side of the rule the panel currently parks on. Labels
      // go on the OPPOSITE side so the panel doesn't occlude them.
      let panelSide = "right";
      // Drag-pan / wheel-zoom both update Vega's `cfdzoom` signal.
      // Vega intercepts mousedown / mouseup on the SVG before our
      // listeners can see them (stopImmediatePropagation), so we
      // can't measure drag distance directly. Instead, watch the
      // zoom signal and remember when it last changed — the
      // synthesised click that fires at the end of a drag-pan
      // arrives within a couple of frames, so an onClick within
      // ~200ms of a zoom-signal change is a drag-end, not a real
      // pin gesture.
      let lastZoomChange = 0;

      // Snap-time annotations: at each band boundary at the snap
      // date, a dashed horizontal line extending LEFT to where the
      // top-of-stack first reached that y-level (i.e. the lead
      // time for items currently at that boundary), labelled
      // "N days"; plus a "N items" count label beside the rule for
      // each band. Built lazily once we know the stage count.
      const guides = {
        built: false, leadLines: [], dayLabels: [],
        labelBoxes: [], itemLabels: [], itemBoxes: [],
      };
      function buildGuides(stageCount) {
        if (guides.built) return;
        function mkText(weight) {
          const t = document.createElementNS(ns, "text");
          t.setAttribute("fill", "#1a1a1a");
          t.setAttribute("font-size", "10");
          t.setAttribute("font-family",
            "-apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif");
          t.setAttribute("font-weight", weight);
          t.setAttribute("pointer-events", "none");
          t.style.opacity = "0";
          return t;
        }
        function mkBox() {
          const r = document.createElementNS(ns, "rect");
          r.setAttribute("fill", "rgba(250, 245, 230, 0.92)");
          r.setAttribute("rx", "2");
          r.setAttribute("pointer-events", "none");
          r.style.opacity = "0";
          return r;
        }
        // n-1 lead-time line + label pairs (one per internal boundary).
        for (let i = 0; i < stageCount - 1; i++) {
          const ln = document.createElementNS(ns, "line");
          ln.setAttribute("data-flow", "y-leadtime");
          ln.setAttribute("stroke", "#1a1a1a");
          ln.setAttribute("stroke-width", "1");
          ln.setAttribute("stroke-dasharray", "4 3");
          ln.setAttribute("pointer-events", "none");
          ln.style.opacity = "0";
          svg.appendChild(ln);
          guides.leadLines.push(ln);
          const box = mkBox();
          const lbl = mkText("500");
          svg.appendChild(box);
          svg.appendChild(lbl);
          guides.labelBoxes.push(box);
          guides.dayLabels.push(lbl);
        }
        // n "N items" labels (one per band, anchored on the rule).
        for (let i = 0; i < stageCount; i++) {
          const box = mkBox();
          const lbl = mkText("600");
          svg.appendChild(box);
          svg.appendChild(lbl);
          guides.itemBoxes.push(box);
          guides.itemLabels.push(lbl);
        }
        guides.built = true;
      }
      function hideGuides() {
        const all = guides.leadLines.concat(
          guides.dayLabels, guides.labelBoxes,
          guides.itemLabels, guides.itemBoxes);
        for (const el of all) el.style.opacity = "0";
      }
      function isoDiffDays(a, b) {
        const da = new Date(a + "T00:00:00Z");
        const db = new Date(b + "T00:00:00Z");
        return Math.round((db - da) / 86400000);
      }
      function paintGuides(iso) {
        const m = metrics[iso];
        if (!m) { hideGuides(); return; }
        const stages = Object.keys(m.stages);
        if (stages.length < 2) { hideGuides(); return; }
        buildGuides(stages.length);
        const xs = view.scale("x");
        const ys = view.scale("y");
        if (!xs || !ys) { hideGuides(); return; }
        const box = plotBox();
        if (!box) { hideGuides(); return; }
        const xX = box.left + xs(new Date(iso + "T00:00:00Z"));

        // cum[i] = sum of WIP[s_i, s_{i+1}, ..., s_{n-1}] at iso —
        // the y-value of the TOP boundary of band i (workflow order).
        const cum = new Array(stages.length);
        let running = 0;
        for (let i = stages.length - 1; i >= 0; i--) {
          running += m.stages[stages[i]] || 0;
          cum[i] = running;
        }
        const dates = Object.keys(metrics);

        // Lead-time lines at every internal boundary
        // (between band i and band i+1, at y = cum[i+1]).
        for (let i = 0; i < stages.length - 1; i++) {
          const yCount = cum[i + 1];
          let D = null;
          // Earliest date where total WIP at D >= yCount = when those
          // items first entered the system.
          for (let j = 0; j < dates.length; j++) {
            const md = metrics[dates[j]];
            if (!md) continue;
            let totalD = 0;
            for (const st of stages) totalD += md.stages[st] || 0;
            if (totalD >= yCount) { D = dates[j]; break; }
          }
          const ln = guides.leadLines[i];
          const lbl = guides.dayLabels[i];
          const lblBox = guides.labelBoxes[i];
          if (D === null || yCount <= 0) {
            ln.style.opacity = "0";
            lbl.style.opacity = "0";
            lblBox.style.opacity = "0";
            continue;
          }
          const xD = box.left + xs(new Date(D + "T00:00:00Z"));
          const yPix = box.top + ys(yCount);
          ln.setAttribute("x1", xD);
          ln.setAttribute("x2", xX);
          ln.setAttribute("y1", yPix);
          ln.setAttribute("y2", yPix);
          // Hide the actual line at zero length; the label still
          // pins to the rule so the reader sees "0 days" rather
          // than nothing.
          ln.style.opacity = D === iso ? "0" : "0.9";
          // Each lead-time line takes the colour of the band it
          // measures — a deep version of the band's pastel so it
          // belongs to that band visually. Band i is the one above
          // boundary i; band i uses palette slot i, which maps to
          // `--cfd-{i+1}`. The boundary loop only runs for
          // i < stages.length - 1, so it never hits the terminal.
          const theme = window.flowmetricsTheme || {};
          const lineColor = theme["cfd-" + (i + 1) + "-deep"] || "#1a1a1a";
          ln.setAttribute("stroke", lineColor);
          ln.setAttribute("stroke-width", "1.5");
          const days = isoDiffDays(D, iso);
          lbl.textContent = days + " days";
          // Anchor the day label on the side OPPOSITE the panel so
          // the panel can't occlude it. Panel right → labels left of
          // rule; panel left → labels right of rule. For zero-length
          // lines, pin to the rule with a small offset either way.
          let labelX, anchor;
          if (panelSide === "right") {
            labelX = (D === iso) ? (xX - 6) : (xD + 5);
            anchor = (D === iso) ? "end" : "start";
          } else {
            labelX = xX + 6;
            anchor = "start";
          }
          lbl.setAttribute("x", labelX);
          lbl.setAttribute("y", yPix - 4);
          lbl.setAttribute("text-anchor", anchor);
          lbl.style.opacity = "1";
          // Size the soft pill behind the label from the rendered bbox.
          const tb = lbl.getBBox();
          lblBox.setAttribute("x", tb.x - 3);
          lblBox.setAttribute("y", tb.y - 1);
          lblBox.setAttribute("width", tb.width + 6);
          lblBox.setAttribute("height", tb.height + 2);
          lblBox.style.opacity = "1";
        }

        // Per-band "N items" labels — at the band's vertical
        // midpoint, just right of the rule.
        for (let i = 0; i < stages.length; i++) {
          const top = cum[i];
          const bottom = i < stages.length - 1 ? cum[i + 1] : 0;
          const wip = m.stages[stages[i]] || 0;
          const tx = guides.itemLabels[i];
          const txBox = guides.itemBoxes[i];
          if (wip <= 0) {
            tx.style.opacity = "0";
            txBox.style.opacity = "0";
            continue;
          }
          const yMid = box.top + ys((top + bottom) / 2);
          tx.textContent = wip + " items";
          // Opposite side of the rule from the panel — see the
          // panelSide comment above. text-anchor flips to keep the
          // label snug against the rule from whichever side.
          const labelX = (panelSide === "right") ? (xX - 6) : (xX + 6);
          const anchor = (panelSide === "right") ? "end" : "start";
          tx.setAttribute("x", labelX);
          tx.setAttribute("y", yMid + 3);
          tx.setAttribute("text-anchor", anchor);
          tx.style.opacity = "1";
          const tb = tx.getBBox();
          txBox.setAttribute("x", tb.x - 3);
          txBox.setAttribute("y", tb.y - 1);
          txBox.setAttribute("width", tb.width + 6);
          txBox.setAttribute("height", tb.height + 2);
          txBox.style.opacity = "1";
        }

        // Collision pass — Vega(-Lite) only ships `labelOverlap`
        // for axis ticks, so this overlay does its own bbox
        // intersection. The "N days" labels carry information that
        // isn't in the panel; the "N items" labels are redundant
        // with the panel's stage table, so they yield first.
        function bbOverlap(a, b) {
          return !(a.x + a.width  <= b.x ||
                   b.x + b.width  <= a.x ||
                   a.y + a.height <= b.y ||
                   b.y + b.height <= a.y);
        }
        const visibleDays = guides.dayLabels.filter(
          function (l) { return l.style.opacity !== "0"; }
        ).map(function (l) { return l.getBBox(); });
        for (let i = 0; i < guides.itemLabels.length; i++) {
          const tx = guides.itemLabels[i];
          const txBox = guides.itemBoxes[i];
          if (tx.style.opacity === "0") continue;
          const ib = tx.getBBox();
          for (const db of visibleDays) {
            if (bbOverlap(ib, db)) {
              tx.style.opacity = "0";
              txBox.style.opacity = "0";
              break;
            }
          }
        }
      }

      function plotBox() {
        const bg = svg.querySelector(".role-frame .background");
        if (!bg) return null;
        const b = bg.getBBox();
        const ctm = bg.getCTM();
        const tx = ctm ? ctm.e : 0, ty = ctm ? ctm.f : 0;
        return {
          left: tx + b.x, top: ty + b.y,
          right: tx + b.x + b.width, bottom: ty + b.y + b.height,
        };
      }
      function visibleDates() {
        // The temporal x-scale's domain is [minDate, maxDate] —
        // not the discrete day list — so iterate METRICS dates
        // and keep the ones currently in view (so a zoomed chart
        // snaps to the right day).
        const xs = view.scale("x");
        if (!xs) return [];
        const dom = xs.domain();
        const lo = dom[0].getTime ? dom[0].getTime() : +dom[0];
        const hi = dom[1].getTime ? dom[1].getTime() : +dom[1];
        return Object.keys(metrics).filter(function (d) {
          const t = Date.parse(d + "T00:00:00Z");
          return t >= lo && t <= hi;
        });
      }
      function nearestDay(svgX, box) {
        const xs = view.scale("x");
        if (!xs) return null;
        const dates = visibleDates();
        let best = null, bestDist = Infinity, bestCx = 0;
        for (let i = 0; i < dates.length; i++) {
          const cx = box.left + xs(new Date(dates[i] + "T00:00:00Z"));
          const dist = Math.abs(svgX - cx);
          if (dist < bestDist) { bestDist = dist; best = dates[i]; bestCx = cx; }
        }
        return best === null ? null : { iso: best, cx: bestCx };
      }
      function val(n) { return (n === null || n === undefined) ? "—" : n; }
      function renderPanel(iso, isPinned) {
        // Look the panel up lazily — it may be parsed into the DOM after
        // this embed callback first runs.
        const panel = document.getElementById("cfd-hover-panel");
        if (!panel) return;
        const m = metrics[iso];
        if (!m) return;
        const bands = Object.keys(m.stages).map(function (s) {
          return "<tr><td>" + s + "</td><td>" + m.stages[s] + "</td></tr>";
        }).join("");
        const pinHeader = isPinned
          ? '<p class="cfd-panel-pin">📌 Pinned · click to release</p>'
          : '';
        panel.innerHTML = pinHeader +
          '<div class="cfd-panel-date">' + m.date_display + '</div>' +
          '<table class="cfd-panel-table"><thead><tr>' +
          '<th>Stage</th><th>Items</th></tr></thead><tbody>' + bands +
          '</tbody></table>' +
          '<table class="cfd-panel-table cfd-panel-flow"><tbody>' +
          '<tr><td>Total WIP</td><td>' + val(m.total_wip) + '</td></tr>' +
          '<tr><td>Arrivals (day)</td><td>' + val(m.arrivals) + '</td></tr>' +
          '<tr><td>Departures (day)</td><td>' + val(m.departures) + '</td></tr>' +
          '<tr><td>Throughput (avg/day)</td><td>' + val(m.throughput) + '</td></tr>' +
          '<tr><td>Avg cycle time (days)</td><td>' + val(m.avg_cycle_time) +
          '</td></tr></tbody></table>';
        if (isPinned) panel.classList.add("is-pinned");
        else panel.classList.remove("is-pinned");
      }
      function placePanel(cxSvg) {
        // Convert the SVG-coord x of the rule to a pixel offset
        // inside the .cfd-tile-wrap that owns the panel's position,
        // then park the panel on whichever side of the rule has more
        // room. Skip on the narrow-viewport breakpoint, where CSS
        // forces the panel back to static.
        const panel = document.getElementById("cfd-hover-panel");
        if (!panel) return;
        const cs = window.getComputedStyle(panel);
        if (cs.position !== "absolute") return;
        const wrap = panel.offsetParent;
        if (!wrap) return;
        const svgRect = svg.getBoundingClientRect();
        const wrapRect = wrap.getBoundingClientRect();
        const vb = svg.viewBox.baseVal;
        const vbw = (vb && vb.width) || svg.clientWidth || 1;
        const screenCx = svgRect.left + cxSvg * svgRect.width / vbw;
        const wrapCx = screenCx - wrapRect.left;
        const panelW = panel.offsetWidth || 200;
        const gap = 16;
        const pad = 12;
        // Prefer the right side of the rule; flip when the panel
        // would clip the chart's right edge.
        let left = wrapCx + gap;
        if (left + panelW > wrapRect.width - pad) {
          left = wrapCx - gap - panelW;
          panelSide = "left";
        } else {
          panelSide = "right";
        }
        // Last-resort clamp — never run off the left edge either.
        if (left < pad) left = pad;
        panel.style.left = left + "px";
        panel.style.right = "auto";
      }
      function moveRule(cx, box) {
        rule.setAttribute("x1", cx);
        rule.setAttribute("x2", cx);
        rule.setAttribute("y1", box.top);
        rule.setAttribute("y2", box.bottom);
        rule.style.opacity = "1";
      }
      function onMove(e) {
        if (pinnedIso !== null) return;
        const rect = svg.getBoundingClientRect();
        const vb = svg.viewBox.baseVal;
        const vbw = (vb && vb.width) || svg.clientWidth;
        const vbh = (vb && vb.height) || svg.clientHeight;
        const svgX = (e.clientX - rect.left) * vbw / rect.width;
        const svgY = (e.clientY - rect.top) * vbh / rect.height;
        const box = plotBox();
        if (!box) return;
        if (svgX < box.left || svgX > box.right ||
            svgY < box.top || svgY > box.bottom) {
          rule.style.opacity = "0";
          hideGuides();
          return;
        }
        const nd = nearestDay(svgX, box);
        if (!nd) return;
        rule.setAttribute("stroke-dasharray", "3 3");
        moveRule(nd.cx, box);
        placePanel(nd.cx);
        renderPanel(nd.iso, false);
        paintGuides(nd.iso);
      }
      function onClick(e) {
        // Click events that arrive within ~200ms of a zoom-signal
        // change are the synthesised click that browsers fire at
        // the end of a drag-pan. Ignore them so panning the chart
        // doesn't jerk the pin to wherever the cursor happened
        // to land.
        if (Date.now() - lastZoomChange < 200) return;
        const rect = svg.getBoundingClientRect();
        const vb = svg.viewBox.baseVal;
        const vbw = (vb && vb.width) || svg.clientWidth;
        const svgX = (e.clientX - rect.left) * vbw / rect.width;
        const box = plotBox();
        if (!box) return;
        if (svgX < box.left || svgX > box.right) return;
        const nd = nearestDay(svgX, box);
        if (!nd) return;
        if (pinnedIso === nd.iso) {
          // Click the pinned day → release.
          pinnedIso = null;
          rule.setAttribute("stroke-dasharray", "3 3");
          moveRule(nd.cx, box);
          placePanel(nd.cx);
          renderPanel(nd.iso, false);
          paintGuides(nd.iso);
        } else {
          pinnedIso = nd.iso;
          rule.setAttribute("stroke-dasharray", "");
          moveRule(nd.cx, box);
          placePanel(nd.cx);
          renderPanel(nd.iso, true);
          paintGuides(nd.iso);
        }
      }
      // Default the panel to the most recent day so it's never an
      // empty block; restore that when the cursor leaves and nothing
      // is pinned.
      const dates = Object.keys(metrics);
      const defaultIso = dates.length ? dates[dates.length - 1] : null;
      function snapDefault() {
        if (!defaultIso) return;
        const xs = view.scale("x");
        const box = plotBox();
        if (!xs || !box) { renderPanel(defaultIso, false); return; }
        const cx = box.left + xs(new Date(defaultIso + "T00:00:00Z"));
        placePanel(cx);
        renderPanel(defaultIso, false);
      }
      // Two animation frames to let CSS layout settle before we
      // measure widths and place the panel.
      requestAnimationFrame(function () {
        requestAnimationFrame(snapDefault);
      });
      // Watch the cfdzoom signal so we can debounce the post-pan
      // synthesised click. Both `cfdzoom_date_iso` (the projected
      // x-axis signal) and `cfdzoom` (the selection object) fire
      // on every drag-pan / wheel-zoom — try the projected one
      // first since it's the one Vega-Lite always creates.
      try {
        view.addSignalListener("cfdzoom_date_iso", function () {
          lastZoomChange = Date.now();
        });
      } catch (_) { /* signal name may differ; resilient */ }
      svg.addEventListener("mousemove", onMove);
      svg.addEventListener("mouseleave", function () {
        if (pinnedIso !== null) return;
        rule.style.opacity = "0";
        hideGuides();
        snapDefault();
      });
      svg.addEventListener("click", onClick);
      window.addEventListener("resize", function () {
        // Keep a pinned panel anchored to its rule across resizes.
        if (pinnedIso === null) { snapDefault(); return; }
        const xs = view.scale("x");
        const box = plotBox();
        if (!xs || !box) return;
        const cx = box.left + xs(new Date(pinnedIso + "T00:00:00Z"));
        moveRule(cx, box);
        placePanel(cx);
      });
    }
  })();
</script>
{% endif %}
