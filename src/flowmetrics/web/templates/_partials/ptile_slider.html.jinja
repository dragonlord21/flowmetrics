{# Page-level Percentile Filter — multi-select chip bar.

   Each non-"All" chip toggles independently; the union of all
   active chips is the effective filter. "All" is a special
   exclusive chip that lifts the filter (deselects everything
   else and sets ptile_ranges to the full band).

   Each chip carries `data-ptile-min` / `data-ptile-max`. On
   click the JS recomputes the active set, builds the
   comma-separated `ptile_ranges` value (e.g. `0-50,85-95`),
   and issues an HTMX request to the work-items endpoint. The
   response carries `HX-Trigger-After-Settle:
   flowmetrics:ptile-changed` so the chart fragment above
   refetches with the same ranges.

   Required context:
     data           — WorkItemsTableData (carries ptile_ranges).
     contract.name  — for the HTMX URL.
#}
{%- set active_ranges = data.ptile_ranges -%}
{%- set is_full = (active_ranges | length == 1 and active_ranges[0][0] == 0 and active_ranges[0][1] == 100) -%}
{%- macro chip(label, lo, hi, ranges, full) -%}
  {%- if lo == 0 and hi == 100 -%}
    {%- set is_active = full -%}
  {%- else -%}
    {%- set is_active = (not full and (lo, hi) in ranges) -%}
  {%- endif -%}
  <button type="button"
          class="ptile-chip{% if is_active %} ptile-chip--active{% endif %}"
          data-ptile-min="{{ lo }}"
          data-ptile-max="{{ hi }}"
          {% if lo == 0 and hi == 100 %}data-ptile-all="1"{% endif %}>
    {{ label }}
  </button>
{%- endmacro -%}
<div class="ptile-toolbar">
  <span class="ptile-toolbar-label">Percentile</span>
  <div class="ptile-chips" id="ptile-chips"
       role="group" aria-label="Percentile filter">
    {{ chip("All", 0, 100, active_ranges, is_full) }}
    {{ chip("≤ P50", 0, 50, active_ranges, is_full) }}
    {{ chip("P50–P85", 50, 85, active_ranges, is_full) }}
    {{ chip("P85–P95", 85, 95, active_ranges, is_full) }}
    {{ chip("> P95", 95, 100, active_ranges, is_full) }}
  </div>
</div>

<script>
  (function () {
    const chips = document.getElementById('ptile-chips');
    if (!chips) return;
    const contract = {{ contract.name | tojson }};

    function activeRanges() {
      const out = [];
      for (const c of chips.querySelectorAll('.ptile-chip--active')) {
        if (c.dataset.ptileAll) continue;  // "All" implies no filter
        out.push([+c.dataset.ptileMin, +c.dataset.ptileMax]);
      }
      return out;
    }

    function fire() {
      const ranges = activeRanges();
      // Empty selection = treat like "All" so the table doesn't
      // go blank — the user clicked the last active chip off.
      const allChip = chips.querySelector('[data-ptile-all="1"]');
      if (!ranges.length) {
        chips.querySelectorAll('.ptile-chip--active').forEach(
          el => el.classList.remove('ptile-chip--active'));
        if (allChip) allChip.classList.add('ptile-chip--active');
      }
      const effective = ranges.length
        ? ranges
        : [[0, 100]];
      const param = effective.map(r => r[0] + '-' + r[1]).join(',');
      const state = document.getElementById('work-items-state');
      const sort = state ? state.dataset.sort : '';
      const dir = state ? state.dataset.direction : '';
      const search = document.getElementById('work-items-search');
      const completedOn = document.getElementById('work-items-completed-on');
      const inFlightAt = document.getElementById('work-items-in-flight-at');
      const qs = new URLSearchParams({
        workflow: contract,
        from: 'slider',
        ptile_ranges: param,
        sort: sort || '',
        direction: dir || '',
        q: search ? search.value : '',
        completed_on: completedOn ? completedOn.value : '',
        in_flight_at: inFlightAt ? inFlightAt.value : '',
      });
      if (window.htmx) {
        window.htmx.ajax('GET', '/api/internal/work-items?' + qs.toString(), {
          target: '#work-items-body', swap: 'innerHTML',
        });
      }
    }

    chips.addEventListener('click', function (e) {
      const btn = e.target.closest('.ptile-chip');
      if (!btn) return;
      if (btn.dataset.ptileAll) {
        // "All" deselects everything else and is the only active.
        chips.querySelectorAll('.ptile-chip--active').forEach(
          el => el.classList.remove('ptile-chip--active'));
        btn.classList.add('ptile-chip--active');
      } else {
        // Toggle this chip. If it becomes active, "All" turns off.
        btn.classList.toggle('ptile-chip--active');
        const allChip = chips.querySelector('[data-ptile-all="1"]');
        if (allChip) allChip.classList.remove('ptile-chip--active');
      }
      fire();
    });
  })();
</script>
