{% extends "_base.html.jinja" %}

{% block filter_bar %}{# no filter bar on the home page — no workflow context #}{% endblock %}

{% block content %}
  <section class="home-intro">
    <h1>Workflows</h1>
    <p class="home-subtitle">
      Pick a workflow to view its flow metrics. Each entry is a
      contract YAML under <code>contracts/</code>.
    </p>
  </section>

  {% if workflows %}
    <ul class="home-workflow-list">
      {% for w in workflows %}
        <li class="home-workflow-item">
          <a class="home-workflow-link" href="/workflows/{{ w.name }}">
            <span class="home-workflow-label">
              <span class="home-workflow-name">{{ w.label }}</span>
              {% if w.label != w.name %}
                <span class="home-workflow-id">{{ w.name }}</span>
              {% endif %}
            </span>
            <span class="home-workflow-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="aging-empty">
      <strong class="aging-empty-headline">No workflows yet.</strong>
      <span class="aging-empty-sub">
        Add a contract YAML under <code>contracts/</code> and
        run <code>flow materialise &lt;name&gt;</code> to
        populate the warehouse.
      </span>
    </p>
  {% endif %}
{% endblock %}
